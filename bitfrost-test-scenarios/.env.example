# Copy to .env and adjust. `.env` is gitignored.

# ── Source checkouts (built by docker compose build) ─────────────────────
HEIMDALL_SRC=../../lantr/heimdall
BINOCULAR_SRC=../../lantr/binocular

# ── Version pins (scripts/00-lib.sh warns when a checkout's HEAD differs) ─
HEIMDALL_REF=400bfcd
BINOCULAR_REF=ba80b5f

# ── Images ───────────────────────────────────────────────────────────────
BITCOIND_IMAGE=bitcoin/bitcoin:28.1
YACI_DEVKIT_IMAGE=bloxbean/yaci-devkit:0.10.5

# ── Bitcoin RPC ──────────────────────────────────────────────────────────
# In-compose regtest by default. For a testnet4 smoke run against an
# external node: point BITCOIN_RPC_URL at it and start compose without the
# bitcoind service (scenario 3 stays regtest-only — it mines CSV blocks).
BITCOIN_RPC_URL=http://bitcoind:18443
BITCOIN_RPC_USER=bifrost
BITCOIN_RPC_PASS=bifrost
