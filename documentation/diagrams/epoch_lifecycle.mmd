gantt
    title Bifrost Epoch Lifecycle — Roster A → Roster B
    dateFormat YYYY-MM-DD HH:mm
    axisFormat %d %b
    tickInterval 1day

    section SPO registration (continuous)
    SPOs register / deregister (always open) :active, reg, 2025-01-01 00:00, 2025-01-11 00:00

    section Epoch N — Roster A controls treasury
    Registry Snapshot + Stake Distr (N−1)  :milestone, n_snap, 2025-01-01 00:00, 0d
    DKG Roster B (off-chain)               :n_dkg, 2025-01-01 00:00, 2025-01-02 11:00
    Peg-in / peg-out requests              :active, n_pegs, 2025-01-01 00:00, 2025-01-02 12:00
    Practical Pegs deadline                :milestone, n_pdl, 2025-01-01 17:00, 0d
    Prev-epoch peg-ins completing (17–40h) :crit, n_prev, 2025-01-01 17:00, 2025-01-02 12:00
    Peg deadline + Pegs Snapshot (3k/f)    :milestone, n_pdl, 2025-01-02 12:00, 0d
    Update Y (Roster A posts Roster B keys)  :n_updy, 2025-01-02 12:00, 2025-01-02 18:00
    Build Treasury Movement Tx (Roster A)  :n_build, 2025-01-02 18:00, 2025-01-03 00:00
    FROST sign 67% (Roster A)              :n_s67, 2025-01-03 00:00, 2025-01-05 23:00
    FROST sign 51% fallback (Roster A)     :crit, n_s51, 2025-01-04 00:00, 2025-01-05 23:00
    Federation TM (last resort)            :crit, n_fed, 2025-01-05 00:00, 2025-01-05 23:00
    TM submission deadline                 :milestone, n_dl, 2025-01-05 23:00, 0d
    New peg requests (next batch)          :n_new, 2025-01-02 12:00, 2025-01-06 00:00

    section Epoch N+1 — Roster B controls treasury
    Registry Snapshot + Stake Distr (N−1)  :milestone, n1_snap, 2025-01-06 00:00, 0d
    DKG Roster C (off-chain)               :n1_dkg, 2025-01-06 00:00, 2025-01-07 11:00
    Peg-in / peg-out requests              :active, n1_pegs, 2025-01-06 00:00, 2025-01-07 12:00
    Practical Pegs deadline                :milestone, n1_pdl, 2025-01-06 17:00, 0d
    Prev-epoch peg-ins completing (17–40h) :crit, n1_prev, 2025-01-06 17:00, 2025-01-07 12:00
    Peg deadline + Pegs Snapshot (3k/f)    :milestone, n1_pdl, 2025-01-07 12:00, 0d
    Update Y (Roster B posts Roster C keys)  :n1_updy, 2025-01-07 12:00, 2025-01-07 18:00
    Build Treasury Movement Tx (Roster B)  :n1_build, 2025-01-07 18:00, 2025-01-08 00:00
    FROST sign 67% (Roster B)              :n1_s67, 2025-01-08 00:00, 2025-01-10 23:00
    FROST sign 51% fallback (Roster B)     :crit, n1_s51, 2025-01-09 00:00, 2025-01-10 23:00
    Federation TM (last resort)            :crit, n1_fed, 2025-01-10 00:00, 2025-01-10 23:00
    TM submission deadline                 :milestone, n1_dl, 2025-01-10 23:00, 0d
    New peg requests (next batch)          :n1_new, 2025-01-07 12:00, 2025-01-11 00:00
    Epoch N+2 · Roster C takes over        :milestone, n2_snap, 2025-01-11 00:00, 0d
